#!/bin/sh
# 禁止将仅本地 AI 助手说明纳入版本库（即使使用 git add -f）
forbidden_bases="AGENTS.md CLAUDE.md GEMINI.md .cursorrules COPILOT.md"
for path in $(git diff --cached --name-only); do
  base=$(basename "$path")
  for f in $forbidden_bases; do
    if [ "$base" = "$f" ]; then
      echo "pre-commit: 拒绝提交「$path」（AI/编辑器本地说明，见 .gitignore）。" >&2
      echo "请从暂存区移除: git reset HEAD -- \"$path\"" >&2
      exit 1
    fi
  done
done

# 当 VERSION 在暂存区中被修改时，自动生成 Docs/appcast.xml（更新内容跟随 commit）
if git diff --cached --name-only | grep -qx "VERSION"; then
  NEW_VERSION=$(cat VERSION | tr -d '[:space:]')
  if [ -n "$NEW_VERSION" ] && [ -d "Docs" ]; then
    # 从上一个 tag 到 HEAD 生成 changelog
    PREV_TAG=$(git describe --tags --abbrev=0 HEAD 2>/dev/null || echo "")
    if [ -n "$PREV_TAG" ]; then
      CHANGELOG=$(git log "$PREV_TAG"..HEAD --pretty=format:"- %s (%h)" --no-merges | head -30)
    else
      CHANGELOG="- Initial release"
    fi

    # 生成 <li> 列表
    ITEMS=""
    while IFS= read -r line; do
      line=$(echo "$line" | sed 's/^- //')
      [ -n "$line" ] && ITEMS="${ITEMS}          <li>${line}</li>
"
    done <<< "$CHANGELOG"

    DESC="        <h3>WaifuX $NEW_VERSION</h3>
        <ul>
${ITEMS}        </ul>"

    PUB_DATE=$(date -R 2>/dev/null || date "+%a, %d %b %Y %H:%M:%S %z")

    python3 -c "
import sys
version, pub_date, desc = sys.argv[1], sys.argv[2], sys.argv[3]
xml = '''<?xml version=\"1.0\" encoding=\"utf-8\"?>
<rss version=\"2.0\" xmlns:sparkle=\"http://www.andymatuschak.org/xml-namespaces/sparkle\" xmlns:dc=\"http://purl.org/dc/elements/1.1/\">
  <channel>
    <title>WaifuX</title>
    <link>https://jipika.github.io/WaifuX/appcast.xml</link>
    <description>WaifuX Updates</description>
    <language>zh</language>
    <item>
      <title>Version {version}</title>
      <sparkle:version>{version}</sparkle:version>
      <sparkle:shortVersionString>{version}</sparkle:shortVersionString>
      <pubDate>{pub_date}</pubDate>
      <description><![CDATA[
{desc}
      ]]></description>
      <enclosure
        url=\"https://github.com/jipika/WaifuX/releases/download/v{version}/WaifuX.dmg\"
        type=\"application/octet-stream\"
        length=\"0\"
      />
    </item>
  </channel>
</rss>'''.format(version=version, pub_date=pub_date, desc=desc)
with open('Docs/appcast.xml', 'w') as f:
    f.write(xml)
" "$NEW_VERSION" "$PUB_DATE" "$DESC"

    git add Docs/appcast.xml
    echo "✅ appcast.xml 已自动生成 -> $NEW_VERSION (changelog from ${PREV_TAG:-初始版本})"
  fi
fi

exit 0
